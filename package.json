{
  "name": "iso-bundler",
  "version": "1.0.0",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "iso-bundler": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "test": "bun test",
    "build": "bun build src/index.tsx --compile --outfile=iso-bundler",
    "build:win": "bun build src/index.tsx --compile --target=bun-windows-x64 --outfile=iso-bundler.exe",
    "build:mac": "bun build src/index.tsx --compile --target=bun-darwin-x64 --outfile=iso-bundler-mac",
    "build:linux": "bun build src/index.tsx --compile --target=bun-linux-x64 --outfile=iso-bundler-linux"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "18.3.0",
    "ink-testing-library": "4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inkjs/ui": "2.0.0",
    "ink": "5.0.1",
    "react": "18.3.1",
    "react-devtools-core": "^7.0.1"
  }
}
