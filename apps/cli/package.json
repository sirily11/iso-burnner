{
    "name": "@iso-bundler/cli",
    "version": "1.0.0",
    "private": true,
    "module": "src/index.tsx",
    "type": "module",
    "bin": {
        "iso-bundler": "./src/index.tsx"
    },
    "scripts": {
        "start": "bun run src/index.tsx",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.tsx --compile --target=bun-windows-x64 --outfile=iso-bundler.exe",
        "build:win": "bun build src/index.tsx --compile --target=bun-windows-x64 --outfile=iso-bundler.exe"
    },
    "dependencies": {
        "@inkjs/ui": "2.0.0",
        "@iso-bundler/core": "workspace:*",
        "ink": "5.0.1",
        "react": "18.3.1",
        "react-devtools-core": "^7.0.1"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/react": "18.3.0",
        "ink-testing-library": "4.0.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}